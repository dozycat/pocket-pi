{
  "name": "pocket-pi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "QuickJS runtime for pi-class agent loops — the Pocket runtime family's agent-domain member",
  "license": "MIT",
  "repository": "github:pocket-stack/pocket-pi",
  "scripts": {
    "codegen": "node spec/codegen.mjs",
    "codegen:check": "node spec/codegen.mjs --check",
    "build:host": "cargo build --manifest-path host/Cargo.toml --release",
    "build:hello": "node build/bundle.mjs examples/hello.ts --out dist/hello.js",
    "test": "node spec/codegen.mjs --check && node test/e2e.mjs",
    "gen:cat": "node stage/gen-assets.mjs",
    "build:cat": "node stage/gen-assets.mjs && cargo build --release --manifest-path stage/Cargo.toml",
    "cat": "node stage/gen-assets.mjs && cargo run --release --manifest-path stage/Cargo.toml",
    "cat:capture": "node stage/gen-assets.mjs && cargo run --release --manifest-path stage/Cargo.toml -- --capture stage/captures"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
